DFA_APP_ENV=development
DFA_POSTGRES_DSN=sqlite:///./discord_research.db
DFA_REDIS_URL=redis://localhost:6379/0
DFA_RUNTYPE=USERT
DFA_DISCORD_BOT_TOKEN=
DFA_OPENROUTER_API_KEY=
DFA_ANONYMIZATION_SALT=change-me

# AnySolver captcha configuration
# Get your API key from https://anysolver.com/dashboard
DFA_ANYSOLVER_API_KEY=
DFA_ANYSOLVER_BASE_URL=https://api.anysolver.com

# Task type submitted to AnySolver for Discord hCaptcha challenges.
# Discord uses enterprise invisible hCaptcha → PopularCaptchaEnterpriseInvisibleTokenProxyLess
DFA_CAPTCHA_TASK_TYPE=PopularCaptchaEnterpriseInvisibleTokenProxyLess

# Optional provider name forwarded in every AnySolver createTask body (e.g. EZCaptcha).
# Leave empty to use the default AnySolver routing.
DFA_CAPTCHA_PROVIDER=

# SSL/TLS verification (set to false ONLY for troubleshooting weak certificates)
DFA_CAPTCHA_SSL_VERIFY=true
# Optional: path to a custom CA bundle file
DFA_CAPTCHA_CA_BUNDLE_PATH=
