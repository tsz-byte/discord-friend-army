DFA_APP_ENV=development
DFA_POSTGRES_DSN=sqlite:///./discord_research.db
DFA_REDIS_URL=redis://localhost:6379/0
DFA_RUNTYPE=USERT
DFA_DISCORD_BOT_TOKEN=
DFA_OPENROUTER_API_KEY=
DFA_ANONYMIZATION_SALT=change-me

# AnySolver captcha configuration
# Get your API key from https://anysolver.com/dashboard
DFA_ANYSOLVER_API_KEY=
DFA_ANYSOLVER_BASE_URL=https://api.anysolver.com

# Task type submitted to AnySolver for Discord hCaptcha challenges.
# Discord uses enterprise invisible hCaptcha → PopularCaptchaEnterpriseInvisibleTokenProxyLess
DFA_CAPTCHA_TASK_TYPE=PopularCaptchaEnterpriseInvisibleTokenProxyLess

# Optional provider name forwarded in every AnySolver createTask body (e.g. EZCaptcha).
# Leave empty to use the default AnySolver routing.
DFA_CAPTCHA_PROVIDER=

# SSL/TLS verification (set to false ONLY for troubleshooting weak certificates)
DFA_CAPTCHA_SSL_VERIFY=true
# Optional: path to a custom CA bundle file
DFA_CAPTCHA_CA_BUNDLE_PATH=
# Optional: fail solved captchas when solution.raw.contextId is empty
DFA_CAPTCHA_REQUIRE_CONTEXT_ID=false

# Discord client fingerprint — update when Discord pushes a new web-client build.
# Read window.GLOBAL_ENV.BUILD_NUMBER from the Discord web app to get the current value.
DFA_DISCORD_CLIENT_BUILD_NUMBER=375000
# Chrome version to mimic in User-Agent and X-Super-Properties.
DFA_DISCORD_CHROME_VERSION=136.0.0.0

# Join attempt response logging.
# When enabled every Discord guild-join attempt (success AND failure) writes a
# structured JSON audit file to the directory below.  Set to false to disable.
DFA_JOIN_FAILURE_LOG_ENABLED=true
DFA_JOIN_FAILURE_LOG_DIR=important_req_logs
# Set to false to only log failed attempts (legacy behaviour).
DFA_JOIN_LOG_ALL_ATTEMPTS=true

# WebSocket gateway session — seconds to wait for Discord READY before falling back
# to a random session_id.  Increase if gateway handshake is slow on your network.
DFA_GATEWAY_SESSION_TIMEOUT=20.0
