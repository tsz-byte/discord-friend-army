DFA_APP_ENV=development
DFA_POSTGRES_DSN=sqlite:///./discord_research.db
DFA_REDIS_URL=redis://localhost:6379/0
DFA_DISCORD_BOT_TOKEN=
DFA_OPENROUTER_API_KEY=
DFA_ANONYMIZATION_SALT=change-me
DFA_EDUCATIONAL_REPLICATION_ONLY=true

# Captcha solver configuration
# Primary service (or comma-separated priority list): anysolver,2captcha,anticaptcha,deathbycaptcha
DFA_CAPTCHA_SERVICE=anysolver
# Optional additional fallback services (comma-separated)
DFA_CAPTCHA_FALLBACK_SERVICES=2captcha,anticaptcha,deathbycaptcha
# Shared API key used by DFA_CAPTCHA_SERVICE when specific per-service key is not provided
DFA_CAPTCHA_API_KEY=
# Optional endpoint override for createTask/getTaskResult style APIs
DFA_CAPTCHA_BASE_URL=
# Provider task type, for example: PopularCaptchaTokenProxyLess, HCaptchaTaskProxyless, RecaptchaV2TaskProxyless
DFA_CAPTCHA_TASK_TYPE=PopularCaptchaTokenProxyLess
# SSL/TLS verification settings (set to false only for troubleshooting weak certificates)
DFA_CAPTCHA_SSL_VERIFY=true
# Optional CA bundle path for custom certificate chains
DFA_CAPTCHA_CA_BUNDLE_PATH=

# Per-service API keys (override DFA_CAPTCHA_API_KEY for the matching provider)
DFA_ANYSOLVER_API_KEY=
DFA_ANYSOLVER_BASE_URL=https://api.anysolver.com
DFA_CAPTCHA_2CAPTCHA_API_KEY=
DFA_ANTICAPTCHA_API_KEY=
# DeathByCaptcha expects username:password format
DFA_DEATHBYCAPTCHA_API_KEY=
